# Images
*.jpg filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text

# Models
*.pth filter=lfs diff=lfs merge=lfs -text

# Data files (but not config files)
*.csv filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text

# Exclude specific text files from LFS
requirements.txt !filter !diff !merge text
requirements-minimal.txt !filter !diff !merge text
commit-message.txt !filter !diff !merge text
*.md !filter !diff !merge text
*.sh !filter !diff !merge text
